{
"Logging": {
  "LogLevel": {
    "Default": "Information",
    "Microsoft.AspNetCore": "Warning"
  }
},
"AllowedHosts": "*",
"Cors": {
  "CacheMinutes": 30
},
"Jwt": {
  "Issuer": "pumpkin-cms-api",
    "Audience": "pumpkin-cms-admin",
    "SecretKey": "REPLACE-WITH-YOUR-SECRET-KEY-MIN-32-CHARS",
    "ExpirationMinutes": 480
  },
  "Database": {
    "Provider": "CosmosDb",
    "CosmosDb": {
      "ConnectionString": "",
      "DatabaseName": "PumpkinCMS",
      "MaxRetryAttemptsOnRateLimitedRequests": 9,
      "MaxRetryWaitTimeOnRateLimitedRequests": 30,
      "PreferredRegions": ""
    },
    "MongoDb": {
      "ConnectionString": "mongodb://localhost:27017",
      "DatabaseName": "PumpkinCMS",
      "MaxConnectionPoolSize": 100,
      "ConnectTimeoutMs": 30000,
      "ServerSelectionTimeoutMs": 30000
    }
  },
  "AssetStorage": {
    "Provider": "AzureBlob",
    "ThemePathTemplate": "tenants/{tenantId}/themes/{themeId}/{version}",
    "MediaPathTemplate": "tenants/{tenantId}/media/{yyyy}/{mm}/{assetId}-{fileName}",
    "MaxThemePackageBytes": 52428800,
    "AzureBlob": {
      "ConnectionString": "",
      "AccountName": "",
      "ThemesContainerName": "pumpkin-themes",
      "MediaContainerName": "pumpkin-media",
      "PublicBaseUrl": "",
      "ThemesPublicBaseUrl": "",
      "MediaPublicBaseUrl": "",
      "UseManagedIdentity": true
    }
  }
}
