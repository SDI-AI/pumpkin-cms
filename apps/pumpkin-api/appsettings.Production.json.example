{
  "Logging": {
    "LogLevel": {
      "Default": "Warning",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "AllowedHosts": "*",
  "Jwt": {
    "Issuer": "pumpkin-cms-api",
    "Audience": "pumpkin-cms-admin",
    "SecretKey": "USE-ENVIRONMENT-VARIABLE-OR-AZURE-KEY-VAULT-MIN-32-CHARS",
    "ExpirationMinutes": 240
  },
  "Database": {
    "Provider": "CosmosDb",
    "CosmosDb": {
      "ConnectionString": "USE-ENVIRONMENT-VARIABLE-OR-AZURE-KEY-VAULT",
      "DatabaseName": "PumpkinCMS",
      "MaxRetryAttemptsOnRateLimitedRequests": 9,
      "MaxRetryWaitTimeOnRateLimitedRequests": 30,
      "PreferredRegions": ""
    }
  },
  "AssetStorage": {
    "Provider": "AzureBlob",
    "ThemePathTemplate": "tenants/{tenantId}/themes/{themeId}/{version}",
    "MediaPathTemplate": "tenants/{tenantId}/media/{assetId}/{fileName}",
    "MaxThemePackageBytes": 52428800,
    "MaxMediaAssetBytes": 26214400,
    "AzureBlob": {
      "ConnectionString": "",
      "AccountName": "USE-AZURE-STORAGE-ACCOUNT-NAME",
      "ThemesContainerName": "pumpkin-themes",
      "MediaContainerName": "pumpkin-media",
      "PublicBaseUrl": "https://USE-STORAGE-ACCOUNT.blob.core.windows.net",
      "ThemesPublicBaseUrl": "",
      "MediaPublicBaseUrl": "",
      "UseManagedIdentity": true
    }
  }
}
